rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isDoctor(uid) {
      return isAuthenticated() && userDoc(uid).data.rol == 'doctor';
    }

    function isAdmin(uid) {
      return isAuthenticated() && userDoc(uid).data.rol == 'admin';
    }

    function isAssignedDoctor(patientUid) {
      return isDoctor(request.auth.uid) &&
        userDoc(patientUid).data.doctorId == request.auth.uid;
    }

    function isPatientUpdatingOwnDoctorNotification(doctorUid) {
      return isAuthenticated() &&
        request.auth.uid != doctorUid &&
        userDoc(request.auth.uid).data.rol == 'paciente' &&
        userDoc(request.auth.uid).data.doctorId == doctorUid;
    }

    match /users/{uid} {
      // Owner can read/write their document.
      // Doctor can read assigned patient profile.
      allow read: if isAuthenticated() &&
        (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
      allow write: if isAuthenticated() &&
        (request.auth.uid == uid || isAdmin(request.auth.uid));

      match /medicamentos/{docId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
        allow write: if isAuthenticated() &&
          (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
      }

      match /citas/{docId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
        allow write: if isAuthenticated() &&
          (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
      }

      match /progresos/{docId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == uid || isAssignedDoctor(uid) || isAdmin(request.auth.uid));
        allow write: if isAuthenticated() &&
          (request.auth.uid == uid || isAdmin(request.auth.uid));
      }

      match /notificaciones/{docId} {
        allow read: if isAuthenticated() &&
          (request.auth.uid == uid || isAdmin(request.auth.uid));
        allow write: if isAuthenticated() &&
          (request.auth.uid == uid ||
            isPatientUpdatingOwnDoctorNotification(uid) ||
            isAdmin(request.auth.uid));
      }

      match /{subcollection}/{docId} {
        allow read, write: if isAuthenticated() &&
          (request.auth.uid == uid || isAdmin(request.auth.uid));
      }
    }
  }
}
